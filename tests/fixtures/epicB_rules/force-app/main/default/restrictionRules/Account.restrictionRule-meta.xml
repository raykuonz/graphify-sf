<?xml version="1.0" encoding="UTF-8"?>
<RestrictionRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <description>Restrict access to internal accounts only</description>
    <enforcementType>Restriction</enforcementType>
    <masterLabel>Account Restriction Rule</masterLabel>
    <recordFilter>IsInternal__c = true</recordFilter>
    <targetEntity>Account</targetEntity>
    <userCriteria>Profile.Name = 'Sales Rep'</userCriteria>
</RestrictionRule>
