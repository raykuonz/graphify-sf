# graphify-sf environment variables
# Copy this file to .env and fill in the values you need.
# Only the variables relevant to your setup are required.

# ---------------------------------------------------------------------------
# LLM Backend API Keys (only set the one matching --backend)
# ---------------------------------------------------------------------------

# Claude (--backend claude)
# ANTHROPIC_API_KEY=

# Gemini (--backend gemini) — either key works
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Kimi K2 (--backend kimi)
# MOONSHOT_API_KEY=

# OpenAI (--backend openai)
# OPENAI_API_KEY=

# AWS Bedrock (--backend bedrock) — uses the standard AWS credential chain
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Ollama (--backend ollama) — local model, no API key needed
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder:7b

# ---------------------------------------------------------------------------
# LLM Model Overrides (optional — defaults are set per backend)
# ---------------------------------------------------------------------------

# Override the Gemini model (default: gemini-2.0-flash)
# GRAPHIFY_SF_GEMINI_MODEL=gemini-2.0-pro

# Override the OpenAI model (default: gpt-4.1-mini)
# GRAPHIFY_SF_OPENAI_MODEL=gpt-4.1

# Override the Bedrock model (default: anthropic.claude-3-5-sonnet-20241022-v2:0)
# GRAPHIFY_SF_BEDROCK_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0

# ---------------------------------------------------------------------------
# LLM Tuning (optional)
# ---------------------------------------------------------------------------

# Max output tokens per LLM API call (default: backend-specific, ~16384)
# GRAPHIFY_SF_MAX_OUTPUT_TOKENS=8192

# API request timeout in seconds (default: 600)
# GRAPHIFY_SF_API_TIMEOUT=120

# Ollama: override KV-cache context window size (default: auto-calculated)
# GRAPHIFY_SF_OLLAMA_NUM_CTX=16384

# Ollama: how long to keep the model loaded between calls (default: 30m)
# GRAPHIFY_SF_OLLAMA_KEEP_ALIVE=30m

# Ollama: allow parallel chunk requests (default: off — single GPU constraint)
# GRAPHIFY_SF_OLLAMA_PARALLEL=1

# ---------------------------------------------------------------------------
# Pipeline Behaviour (optional)
# ---------------------------------------------------------------------------

# Default output directory (default: graphify-sf-out)
# GRAPHIFY_SF_OUT=graphify-sf-out

# Always overwrite graph.json even if the new graph is smaller (default: off)
# GRAPHIFY_SF_FORCE=1

# Max nodes before the HTML viz switches to aggregated community view (default: 5000)
# GRAPHIFY_SF_VIZ_NODE_LIMIT=5000

# Cap memory (MB) for background watch-mode rebuilds (default: unlimited)
# GRAPHIFY_SF_REBUILD_MEMORY_LIMIT_MB=512

# ---------------------------------------------------------------------------
# Claude Code Integration (optional)
# ---------------------------------------------------------------------------

# Override the Claude Code config directory (default: ~/.claude).
# Claude Code itself reads this variable; graphify-sf follows it when
# installing the /graphify-sf skill and writing CLAUDE.md entries.
# Only set this if your Claude Code config lives somewhere other than ~/.claude
# (e.g. company-managed dotfiles, CI environments, or multiple installations).
# CLAUDE_CONFIG_DIR=/path/to/custom/.claude
